    "db:migrate": "prisma migrate dev --schema=../../apps/api/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "devDependencies": {
    "prisma": "^6.19.2",
    "typescript": "^5.9.3"
  }
}
