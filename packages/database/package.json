{
  "name": "@meta-geniusz/database",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "prisma generate --schema=../../apps/api/prisma/schema.prisma",
