generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  bio       String?
  createdAt DateTime @default(now())

  posts     Post[]
}

model Post {
  id        String   @id @default(uuid())
  content   String
  image     String?
  createdAt DateTime @default(now())

  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}